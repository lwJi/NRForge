# Parameter definitions for thorn SingleBH

SHARES: ADMBaseX

EXTENDS KEYWORD initial_data 
{
  "KerrSchild" :: "Kerr metric in Kerr-Schild coordinates"
  "Schwarzschild" :: "Schwarzschild metric"
} 



PRIVATE:

CCTK_REAL mass "mass of the black hole"
{
  0.0:* :: ""
} 1.0

CCTK_REAL angv "rotational parameter of the spin object"
{
  0.0:* :: ""
} 0.0

CCTK_REAL epsilon "Avoid division by zero"
{
  0:* :: ""
} 1.0e-8
